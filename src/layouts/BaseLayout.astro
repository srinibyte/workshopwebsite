---
type Props = {
	title?: string;
	description?: string;
	bodyClass?: string;
};

const {
	title = "prahlad's workshop",
	description = "prahlad's hq",
	bodyClass = ''
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" href="/favicon.png?v=4" type="image/png" />
		<link rel="icon" href="/favicon-32.png?v=4" sizes="32x32" type="image/png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=4" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Spectral:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="stylesheet" href="/styles/global.css" />
		<script is:inline>
			(() => {
				const storedTheme = window.localStorage.getItem('theme');
				const theme =
					storedTheme === 'dark'
						? 'dark'
						: 'light';
				document.documentElement.dataset.theme = theme;
			})();
		</script>
	</head>
	<body class={bodyClass}>
		<div class="site-shell">
			<header class="site-header">
				<div class="header-actions">
					<nav class="site-nav" aria-label="Primary">
						<a class="home-link" href="/" data-clicky>Home</a>
						<a href="/blog" data-clicky>Blog</a>
						<a href="/notes" data-clicky>Notes</a>
						<a href="/projects" data-clicky>Projects</a>
						<a href="/contact" data-clicky>About</a>
					</nav>
					<button
						class="theme-toggle"
						type="button"
						data-theme-toggle
						aria-label="Switch to dark mode"
						data-clicky
					>
						<span class="theme-toggle-sun" aria-hidden="true"></span>
						<span class="theme-toggle-moon" aria-hidden="true"></span>
						<span class="sr-only" data-theme-label>Light mode</span>
					</button>
				</div>
			</header>

			<slot />
		</div>

		<script is:inline>
			(() => {
				for (const link of document.querySelectorAll('a[href]')) {
					if (!(link instanceof HTMLAnchorElement)) continue;

					const url = new URL(link.href, window.location.href);
					if (!['http:', 'https:'].includes(url.protocol) || url.origin === window.location.origin) {
						continue;
					}

					link.target = '_blank';
					link.rel = 'noopener noreferrer';
				}

				let audioContext;

				const clickTone = () => {
					audioContext ??= new window.AudioContext();
					if (audioContext.state === 'suspended') audioContext.resume();

					const now = audioContext.currentTime;
					const tone = audioContext.createOscillator();
					const hiss = audioContext.createBufferSource();
					const toneGain = audioContext.createGain();
					const hissGain = audioContext.createGain();
					const mix = audioContext.createGain();
					const hissBuffer = audioContext.createBuffer(1, audioContext.sampleRate * 0.014, audioContext.sampleRate);
					const hissData = hissBuffer.getChannelData(0);

					for (let i = 0; i < hissData.length; i += 1) {
						const envelope = Math.exp(-i / 42);
						hissData[i] = (Math.random() * 2 - 1) * envelope;
					}

					tone.type = 'sine';
					tone.frequency.setValueAtTime(1240, now);
					tone.frequency.exponentialRampToValueAtTime(860, now + 0.018);

					toneGain.gain.setValueAtTime(0.0001, now);
					toneGain.gain.exponentialRampToValueAtTime(0.022, now + 0.001);
					toneGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.018);

					hissGain.gain.setValueAtTime(0.0001, now);
					hissGain.gain.exponentialRampToValueAtTime(0.018, now + 0.0006);
					hissGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.013);

					mix.gain.value = 0.9;

					tone.connect(toneGain);
					toneGain.connect(mix);
					hiss.buffer = hissBuffer;
					hiss.connect(hissGain);
					hissGain.connect(mix);
					mix.connect(audioContext.destination);

					tone.start(now);
					tone.stop(now + 0.02);
					hiss.start(now);
					hiss.stop(now + 0.014);
				};

				document.addEventListener('pointerup', (event) => {
					const target = event.target;
					if (!(target instanceof Element)) return;
					const link = target.closest('a[href]');
					if (!link) return;
					if (link.hasAttribute('download')) return;
					clickTone();
				});

				const searchGroupNames = new Set(
					[...document.querySelectorAll('[data-filter-group], [data-search-group]')]
						.map((node) => node.getAttribute('data-filter-group') || node.getAttribute('data-search-group'))
						.filter(Boolean)
				);

				for (const targetName of searchGroupNames) {
					const group = document.querySelector(`[data-filter-group="${targetName}"]`);
					const buttons = group ? [...group.querySelectorAll('[data-filter-value]')] : [];
					if (!targetName) continue;
					const searchInput = document.querySelector(`[data-search-group="${targetName}"]`);

					const items = [
						...document.querySelectorAll(`[data-filter-target="${targetName}"]`)
					];

					const update = (value, query) => {
						const normalizedValue = value.trim().toLowerCase();
						for (const button of buttons) {
							button.classList.toggle(
								'is-active',
								(button.getAttribute('data-filter-value') || '').trim().toLowerCase() === normalizedValue
							);
						}

						for (const item of items) {
							const tags = (item.getAttribute('data-tags') || '')
								.split(',')
								.map((tag) => tag.trim().toLowerCase())
								.filter(Boolean);
							const searchText = (item.getAttribute('data-search-text') || '').toLowerCase();
							const matchesTag = !buttons.length || normalizedValue === 'all' || tags.includes(normalizedValue);
							const matchesQuery = !query || searchText.includes(query);
							item.hidden = !(matchesTag && matchesQuery);
						}
					};

					const currentValue = () =>
						buttons.find((button) => button.classList.contains('is-active'))?.getAttribute('data-filter-value') ||
						'all';

					const currentQuery = () =>
						searchInput instanceof HTMLInputElement
							? searchInput.value.trim().toLowerCase()
							: '';

					for (const button of buttons) {
						button.addEventListener('click', () => {
							update(button.getAttribute('data-filter-value') || 'all', currentQuery());
						});
					}

					if (searchInput instanceof HTMLInputElement) {
						searchInput.addEventListener('input', () => {
							update(currentValue(), currentQuery());
						});
					}

					const requestedFilter = new URLSearchParams(window.location.search).get('filter');
					const initialFilter = buttons.some((button) => button.getAttribute('data-filter-value') === requestedFilter)
						? requestedFilter
						: 'all';
					update(initialFilter, currentQuery());
				}

				for (const table of document.querySelectorAll('[data-notion-table]')) {
					const rows = [...table.querySelectorAll('[data-table-row]')];
					const filter = table.querySelector('[data-table-filter]');
					const sortButtons = [...table.querySelectorAll('[data-table-sort]')];
					let currentSort = { index: -1, direction: 'asc' };

					const applyTableFilter = () => {
						if (!(filter instanceof HTMLInputElement)) return;
						const query = filter.value.trim().toLowerCase();
						for (const row of rows) {
							const searchText = row.getAttribute('data-search-text') || '';
							row.hidden = Boolean(query) && !searchText.includes(query);
						}
					};

					const sortRows = (index) => {
						const tbody = table.querySelector('tbody');
						if (!(tbody instanceof HTMLTableSectionElement)) return;
						const direction =
							currentSort.index === index && currentSort.direction === 'asc'
								? 'desc'
								: 'asc';
						currentSort = { index, direction };

						for (const button of sortButtons) {
							const active = Number(button.getAttribute('data-table-sort')) === index;
							button.setAttribute('aria-sort', active ? direction : 'none');
						}

						const sorted = [...rows].sort((a, b) => {
							const aValue = a.children[index]?.getAttribute('data-sort-value') || '';
							const bValue = b.children[index]?.getAttribute('data-sort-value') || '';
							const aNumber = Number(aValue.replace(/,/g, ''));
							const bNumber = Number(bValue.replace(/,/g, ''));
							const bothNumeric = aValue.trim() !== '' && bValue.trim() !== '' && Number.isFinite(aNumber) && Number.isFinite(bNumber);
							const result = bothNumeric
								? aNumber - bNumber
								: aValue.localeCompare(bValue, undefined, { numeric: true, sensitivity: 'base' });
							return direction === 'asc' ? result : -result;
						});

						for (const row of sorted) tbody.append(row);
						applyTableFilter();
					};

					if (filter instanceof HTMLInputElement) {
						filter.addEventListener('input', applyTableFilter);
					}

					for (const button of sortButtons) {
						button.setAttribute('aria-sort', 'none');
						button.addEventListener('click', () => {
							sortRows(Number(button.getAttribute('data-table-sort') || 0));
						});
					}
				}

				const followLabels = [...document.querySelectorAll('[data-follow-label]')];
				for (const hotspot of followLabels) {
					if (!(hotspot instanceof HTMLElement)) continue;

					const updateTooltipPosition = (clientX, clientY) => {
						const rect = hotspot.getBoundingClientRect();
						const x = Math.max(12, Math.min(clientX - rect.left, rect.width - 12));
						const y = Math.max(12, Math.min(clientY - rect.top, rect.height - 12));
						hotspot.style.setProperty('--tooltip-x', `${x}px`);
						hotspot.style.setProperty('--tooltip-y', `${y}px`);
					};

					hotspot.addEventListener('pointermove', (event) => {
						updateTooltipPosition(event.clientX, event.clientY);
					});

					hotspot.addEventListener('pointerenter', (event) => {
						updateTooltipPosition(event.clientX, event.clientY);
					});

					hotspot.addEventListener('focus', () => {
						hotspot.style.setProperty('--tooltip-x', '50%');
						hotspot.style.setProperty('--tooltip-y', '50%');
					});
				}

				const themeToggle = document.querySelector('[data-theme-toggle]');
				const themeLabel = document.querySelector('[data-theme-label]');

				const applyTheme = (theme) => {
					document.documentElement.dataset.theme = theme;
					window.localStorage.setItem('theme', theme);
					if (themeLabel instanceof HTMLElement) {
						themeLabel.textContent = theme === 'dark' ? 'Dark mode' : 'Light mode';
					}
					if (themeToggle instanceof HTMLButtonElement) {
						themeToggle.setAttribute(
							'aria-label',
							theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
						);
					}
				};

				const initialTheme = document.documentElement.dataset.theme === 'dark'
					? 'dark'
					: 'light';
				applyTheme(initialTheme);

				if (themeToggle instanceof HTMLButtonElement) {
					themeToggle.addEventListener('click', () => {
						const currentTheme = document.documentElement.dataset.theme || 'light';
						const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
						applyTheme(nextTheme);
					});
				}

				const identity = window.netlifyIdentity;
				const authHash = window.location.hash;
				const hasIdentityToken =
					authHash.includes('invite_token=') ||
					authHash.includes('confirmation_token=') ||
					authHash.includes('recovery_token=') ||
					authHash.includes('email_change_token=');

				if (identity) {
					identity.on('init', (user) => {
						if (hasIdentityToken && !user) {
							identity.open();
						}
					});

					identity.on('login', () => {
						if (window.location.pathname !== '/admin/') {
							window.location.href = '/admin/';
						}
					});

					if (hasIdentityToken) {
						window.requestAnimationFrame(() => identity.open());
					}
				}
			})();
		</script>
	</body>
</html>
