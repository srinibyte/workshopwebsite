---
type Props = {
	contentId: string;
};

const { contentId } = Astro.props as Props;
---

<div class="like-control" data-like-control data-content-id={contentId}>
	<button class="like-button" type="button" aria-label="Like this post" aria-pressed="false">
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path d="M20.8 4.7a5.5 5.5 0 0 0-7.8 0L12 5.8l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8l1.1 1.1L12 21.4l7.8-7.8 1.1-1.1a5.5 5.5 0 0 0-.1-7.8Z"></path>
		</svg>
		<span data-like-count>0</span>
	</button>
	<span class="sr-only" aria-live="polite" data-like-status></span>
</div>

<script>
	const endpoint = '/.netlify/functions/likes';

	const localLikeKey = (contentId: string) => `workshop:liked:${contentId}`;
	const localCountKey = (contentId: string) => `workshop:likes:${contentId}`;
	const clampCount = (count: number) => Math.max(0, count);

	const storeLocalState = (contentId: string, count: number, liked: boolean) => {
		window.localStorage.setItem(localCountKey(contentId), String(clampCount(count)));
		if (liked) {
			window.localStorage.setItem(localLikeKey(contentId), 'true');
		} else {
			window.localStorage.removeItem(localLikeKey(contentId));
		}
	};

	const applyState = (control: Element, count: number, liked: boolean) => {
		if (!(control instanceof HTMLElement)) return;
		const button = control.querySelector('.like-button');
		const countNode = control.querySelector('[data-like-count]');
		if (!(button instanceof HTMLButtonElement) || !(countNode instanceof HTMLElement)) return;

		countNode.textContent = String(clampCount(count));
		button.classList.toggle('is-liked', liked);
		button.setAttribute('aria-pressed', String(liked));
		button.setAttribute('aria-label', liked ? 'Unlike this post' : 'Like this post');
	};

	const applyStateForContent = (contentId: string, count: number, liked: boolean) => {
		for (const control of document.querySelectorAll('[data-like-control]')) {
			if (!(control instanceof HTMLElement) || control.dataset.contentId !== contentId) continue;
			applyState(control, count, liked);
		}
	};

	const setStatus = (control: Element, message: string) => {
		const status = control.querySelector('[data-like-status]');
		if (status instanceof HTMLElement) status.textContent = message;
	};

	const loadLike = async (control: Element) => {
		if (!(control instanceof HTMLElement)) return;
		const contentId = control.dataset.contentId;
		if (!contentId) return;

		const localLiked = window.localStorage.getItem(localLikeKey(contentId)) === 'true';
		const localCount = Number.parseInt(window.localStorage.getItem(localCountKey(contentId)) || '0', 10);
		applyState(control, localCount, localLiked);

		try {
			const response = await fetch(`${endpoint}?id=${encodeURIComponent(contentId)}`, {
				credentials: 'include'
			});
			if (!response.ok) throw new Error('Likes endpoint unavailable');
			const data = await response.json();
			storeLocalState(contentId, data.count, Boolean(data.liked));
			applyStateForContent(contentId, data.count, Boolean(data.liked));
		} catch {
			// Local Astro development has no Netlify Functions runtime.
		}
	};

	for (const control of document.querySelectorAll('[data-like-control]')) {
		if (control instanceof HTMLElement && control.dataset.likeReady === 'true') continue;
		if (control instanceof HTMLElement) control.dataset.likeReady = 'true';

		void loadLike(control);

		const button = control.querySelector('.like-button');
		if (!(button instanceof HTMLButtonElement) || !(control instanceof HTMLElement)) continue;

		button.addEventListener('click', async () => {
			const contentId = control.dataset.contentId;
			if (!contentId || button.disabled) return;

			const countNode = control.querySelector('[data-like-count]');
			const currentCount = Number.parseInt(countNode?.textContent || '0', 10);
			const currentlyLiked = button.getAttribute('aria-pressed') === 'true';
			const nextLiked = !currentlyLiked;
			const nextCount = clampCount(currentCount + (nextLiked ? 1 : -1));

			button.disabled = true;
			applyStateForContent(contentId, nextCount, nextLiked);
			storeLocalState(contentId, nextCount, nextLiked);
			setStatus(control, nextLiked ? 'Liked' : 'Like removed');

			try {
				const response = await fetch(endpoint, {
					method: 'POST',
					credentials: 'include',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ id: contentId, liked: nextLiked })
				});
				if (!response.ok) throw new Error('Like could not be saved');
				const data = await response.json();
				storeLocalState(contentId, data.count, Boolean(data.liked));
				applyStateForContent(contentId, data.count, Boolean(data.liked));
			} catch {
				applyStateForContent(contentId, currentCount, currentlyLiked);
				storeLocalState(contentId, currentCount, currentlyLiked);
				setStatus(control, 'Like could not be saved.');
			} finally {
				button.disabled = false;
			}
		});
	}
</script>
