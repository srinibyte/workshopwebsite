---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LikeButton from '../../components/LikeButton.astro';
import { formatDate } from '../../lib/content';

export async function getStaticPaths() {
	const posts: CollectionEntry<'blog'>[] = (await getCollection('blog')).filter(
		(post: CollectionEntry<'blog'>) => !post.data.draft
	);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post }
	}));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - Prahlad Srinivasan`} description={post.data.description}>
	<main class="post-page">
		<header class="post-header">
			<p class="back-row">
				<a class="back-link" href="/blog" data-clicky>Back to Blog</a>
			</p>
			<div class="post-meta-row">
				<time>{formatDate(post.data.date)}</time>
				<LikeButton contentId={`blog:${post.id}`} />
			</div>
			<h1>{post.data.title}</h1>
			<p class="post-dek">{post.data.description}</p>
			<div class="tag-row">
				{post.data.tags.map((tag: string) => <span>{tag}</span>)}
			</div>
		</header>

		{post.data.coverImage ? (
			<figure class="post-cover">
				<img
					src={post.data.coverImage}
					alt={post.data.coverImageAlt || post.data.title}
					loading="eager"
				/>
			</figure>
		) : null}

		<article class="prose">
			<Content />
		</article>

		{post.data.authorNote ? (
			<section class="author-note">
				<p class="author-note-label">Author's note</p>
				<p>{post.data.authorNote}</p>
			</section>
		) : null}

	</main>
</BaseLayout>
