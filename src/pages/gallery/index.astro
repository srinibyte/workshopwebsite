---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { extractMarkdownImages, formatDate, slugToId } from '../../lib/content';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes'))
	.filter((note: CollectionEntry<'notes'>) => !note.data.draft)
	.sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.date.valueOf() - a.data.date.valueOf());

const posts: CollectionEntry<'blog'>[] = (await getCollection('blog'))
	.filter((post: CollectionEntry<'blog'>) => !post.data.draft)
	.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf());

const noteItems = notes.flatMap((note: CollectionEntry<'notes'>) =>
	note.data.images.map((image: { src: string; alt: string; caption?: string }, index: number) => ({
		id: `${note.id}-${index}`,
		kind: 'Notes',
		date: note.data.date,
		title: note.data.title,
		subtitle: note.data.summary,
		image: image.src,
		alt: image.alt,
		caption: image.caption,
		href: `/notes#${slugToId(note.id)}`,
		search: [note.data.title, note.data.summary, note.data.tags.join(' '), image.caption || '']
			.join(' ')
			.toLowerCase()
	}))
);

const blogItems = posts.flatMap((post: CollectionEntry<'blog'>) =>
	extractMarkdownImages(post.body).map((image, index) => ({
		id: `${post.id}-${index}`,
		kind: 'Blog',
		date: post.data.date,
		title: post.data.title,
		subtitle: post.data.description,
		image: image.src,
		alt: image.alt,
		caption: post.data.authorNote,
		href: `/blog/${post.id}`,
		search: [post.data.title, post.data.description, post.data.tags.join(' '), image.alt].join(' ').toLowerCase()
	}))
);

const galleryItems = [...blogItems, ...noteItems].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const noteCount = noteItems.length;
const blogCount = blogItems.length;
const totalCount = galleryItems.length;
const latestDate = galleryItems[0]?.date;
---

<BaseLayout title="Gallery - Prahlad Srinivasan" description="Illustrated gallery of images from blog posts and notes.">
	<main class="content-page gallery-page">
		<header class="page-top gallery-hero">
			<div class="gallery-hero-copy">
				<p class="gallery-kicker">Photos / archive</p>
				<h1>Gallery</h1>
				<p>
					An image archive pulled from blog posts and notes, rebuilt as a cleaner editorial index with each
					photo linking back to its source.
				</p>
			</div>

			<div class="gallery-stats" aria-label="Gallery stats">
				<div>
					<span>Images</span>
					<strong>{totalCount}</strong>
				</div>
				<div>
					<span>Blog</span>
					<strong>{blogCount}</strong>
				</div>
				<div>
					<span>Notes</span>
					<strong>{noteCount}</strong>
				</div>
				<div>
					<span>Updated</span>
					<strong>{latestDate ? formatDate(latestDate) : '—'}</strong>
				</div>
			</div>
		</header>

		{totalCount ? (
			<div class="tag-filter gallery-filter" data-filter-group="gallery">
				<button class="tag-pill is-active" data-filter-value="all" type="button">All</button>
				<button class="tag-pill" data-filter-value="Blog" type="button">Blog</button>
				<button class="tag-pill" data-filter-value="Notes" type="button">Notes</button>
			</div>
		) : null}

		<section class="gallery-feed" aria-label="Gallery items">
			{galleryItems.map((item) => (
				<a
					class="gallery-story"
					href={item.href}
					data-clicky
					data-filter-target="gallery"
					data-tags={item.kind}
					data-search-text={item.search}
				>
					<div class="gallery-story-media">
						<img src={item.image} alt={item.alt} loading="lazy" />
					</div>

					<div class="gallery-story-copy">
						<div class="tag-row gallery-story-meta">
							<span>{item.kind}</span>
							<span>{formatDate(item.date)}</span>
						</div>
						<h2>{item.title}</h2>
						<p>{item.subtitle}</p>
						{item.caption ? <small>{item.caption}</small> : null}
					</div>
				</a>
			))}
		</section>
	</main>
</BaseLayout>
