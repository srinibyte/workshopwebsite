---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Prahlad Srinivasan" description="Contact Prahlad Srinivasan.">
	<main class="contact-page">
		<section class="business-card static-card">
			<div class="card-surface">
				<p class="card-label">Contact</p>
				<h1>PRAHLAD SRINIVASAN</h1>
				<p class="card-role">Writer, tinkerer, and builder.</p>
				<a class="contact-email" href="mailto:prahladxsrinivasan@gmail.com" data-clicky>
					prahladxsrinivasan@gmail.com
				</a>

				<div class="social-row">
					<a href="https://www.linkedin.com/in/prahladsrini" target="_blank" rel="noreferrer" data-clicky>
						LinkedIn
					</a>
					<a href="https://www.instagram.com/prahladsrini" target="_blank" rel="noreferrer" data-clicky>
						Instagram
					</a>
					<a href="https://twitter.com/prahladsrini" target="_blank" rel="noreferrer" data-clicky>
						Twitter
					</a>
				</div>

				<p class="admin-row">
					<a class="admin-link" href="/admin" data-clicky>Admin</a>
				</p>
			</div>
		</section>
	</main>
</BaseLayout>
