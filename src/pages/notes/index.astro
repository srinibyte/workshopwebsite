---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, slugToId } from '../../lib/content';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes'))
	.filter((note: CollectionEntry<'notes'>) => !note.data.draft)
	.sort(
		(a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) =>
			b.data.date.valueOf() - a.data.date.valueOf()
	);

const renderedNotes = await Promise.all(
	notes.map(async (note: CollectionEntry<'notes'>) => ({
		note,
		...(await render(note))
	}))
);

const counts = {
	all: notes.length,
	bookmark: notes.filter((note) => note.data.kind === 'bookmark').length,
	photo: notes.filter((note) => note.data.kind === 'photo').length,
	note: notes.filter((note) => note.data.kind === 'note').length
};
---

<BaseLayout title="Notes - Prahlad Srinivasan" description="Short notes, bookmarks, and photos by Prahlad Srinivasan.">
	<main class="content-page notes-page">
		<header class="page-top notes-page-header">
			<div>
				<h1>Notes</h1>
				<p>Short pieces: something written, saved, or seen.</p>
			</div>
		</header>

		<div class="notes-layout">
			<aside class="notes-sidebar">
				<p class="notes-sidebar-label">Browse</p>
				<nav class="notes-filter" aria-label="Filter notes" data-filter-group="notes">
					<button class="notes-filter-button is-active" type="button" data-filter-value="all">
						<span>All</span>
						<small>{counts.all}</small>
					</button>
					<button class="notes-filter-button" type="button" data-filter-value="bookmark">
						<span>Bookmarks</span>
						<small>{counts.bookmark}</small>
					</button>
					<button class="notes-filter-button" type="button" data-filter-value="photo">
						<span>Photos</span>
						<small>{counts.photo}</small>
					</button>
					<button class="notes-filter-button" type="button" data-filter-value="note">
						<span>Notes</span>
						<small>{counts.note}</small>
					</button>
				</nav>
			</aside>

			<section class="notes-stream" aria-label="Notes feed">
				{renderedNotes.map(({ note, Content }) => (
					<article
						id={slugToId(note.id)}
						class:list={['note-entry', `note-entry-${note.data.kind}`]}
						data-filter-target="notes"
						data-tags={note.data.kind}
					>
						<header class="note-entry-header">
							<div>
								<p class="note-entry-kind">{note.data.kind}</p>
								<h2>{note.data.title}</h2>
							</div>
							<time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
						</header>

						{note.data.summary ? <p class="note-entry-summary">{note.data.summary}</p> : null}

						{note.data.coverImage ? (
							<figure class="note-entry-cover">
								<img
									src={note.data.coverImage}
									alt={note.data.coverImageAlt || note.data.title}
									loading="lazy"
								/>
							</figure>
						) : null}

						<div class="prose note-entry-body">
							<Content />
						</div>

						{note.data.externalUrl ? (
							<p class="note-entry-link">
								<a href={note.data.externalUrl} target="_blank" rel="noreferrer" data-clicky>
									Visit bookmark
								</a>
							</p>
						) : null}

						{note.data.tags.length ? (
							<div class="tag-row note-entry-tags">
								{note.data.tags.map((tag: string) => <span>{tag}</span>)}
							</div>
						) : null}
					</article>
				))}

				{notes.length === 0 ? (
					<p class="notes-empty">No notes yet.</p>
				) : null}
			</section>
		</div>
	</main>
</BaseLayout>
