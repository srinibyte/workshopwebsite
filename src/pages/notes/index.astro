---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { extractMarkdownImages, formatDate, slugToId } from '../../lib/content';

const notes: CollectionEntry<'notes'>[] = (await getCollection('notes'))
	.filter((note: CollectionEntry<'notes'>) => !note.data.draft)
	.sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.date.valueOf() - a.data.date.valueOf());

const posts: CollectionEntry<'blog'>[] = (await getCollection('blog'))
	.filter((post: CollectionEntry<'blog'>) => !post.data.draft)
	.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf());

const bookmarks = notes
	.filter((note) => Boolean(note.data.externalUrl))
	.map((note) => ({
		id: note.id,
		title: note.data.title,
		date: note.data.date,
		tags: note.data.tags,
		summary: note.data.summary,
		href: note.data.externalUrl || `/notes#${slugToId(note.id)}`
	}));

const photoEntries = [
	...notes.flatMap((note) =>
		note.data.images.map((image: { src: string; alt: string; caption?: string }, index: number) => ({
			id: `${note.id}-${index}`,
			type: 'note',
			title: note.data.title,
			date: note.data.date,
			href: `/notes#${slugToId(note.id)}`,
			image: image.src,
			alt: image.alt,
			caption: image.caption || note.data.summary,
			tags: note.data.tags
		}))
	),
	...posts.flatMap((post) =>
		extractMarkdownImages(post.body).map((image, index) => ({
			id: `${post.id}-${index}`,
			type: 'blog',
			title: post.data.title,
			date: post.data.date,
			href: `/blog/${post.id}`,
			image: image.src,
			alt: image.alt,
			caption: post.data.description,
			tags: post.data.tags
		}))
	)
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

const tracks = posts.map((post) => ({
	id: post.id,
	title: post.data.title,
	date: post.data.date,
	tags: post.data.tags,
	description: post.data.description,
	href: `/blog/${post.id}`
}));

const textNotes = notes
	.filter((note) => !note.data.externalUrl && !note.data.images.length)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedNotes = await Promise.all(
	textNotes.map(async (note) => ({
		note,
		...(await render(note))
	}))
);

const totalItems = bookmarks.length + tracks.length + photoEntries.length + renderedNotes.length;
const latestDate = [...notes, ...posts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]?.data.date;
---

<BaseLayout title="Notes - Prahlad Srinivasan" description="Bookmarks, tracks, photos, and notes by Prahlad Srinivasan.">
	<main class="content-page notes-hub">
		<header class="page-top notes-hero">
			<div class="notes-hero-copy">
				<p class="gallery-kicker">Issue dated {latestDate ? formatDate(latestDate) : '—'}</p>
				<h1>Notes</h1>
				<p>
					A single living notebook for bookmarks, longer tracks, photos, and plain notes. Everything now sits
					in one place, with sections that keep the site readable.
				</p>
			</div>

			<div class="gallery-stats notes-stats" aria-label="Notes stats">
				<div>
					<span>Entries</span>
					<strong>{totalItems}</strong>
				</div>
				<div>
					<span>Bookmarks</span>
					<strong>{bookmarks.length}</strong>
				</div>
				<div>
					<span>Photos</span>
					<strong>{photoEntries.length}</strong>
				</div>
				<div>
					<span>Notes</span>
					<strong>{renderedNotes.length}</strong>
				</div>
			</div>
		</header>

		<nav class="notes-sections" aria-label="Notes sections">
			<a href="#bookmarks">Bookmarks</a>
			<a href="#tracks">Tracks</a>
			<a href="#photos">Photos</a>
			<a href="#notes">Notes</a>
		</nav>

		<section id="bookmarks" class="notes-section" aria-labelledby="bookmarks-heading">
			<div class="section-heading">
				<h2 id="bookmarks-heading">Bookmarks</h2>
				<p>Links I’ve saved for later, with short context and the original source.</p>
			</div>

			<div class="notes-section-list">
				{bookmarks.map((item) => (
					<article class="notes-entry notes-bookmark">
						<div class="notes-entry-meta">
							<span>Bookmark</span>
							<time>{formatDate(item.date)}</time>
						</div>
						<h3>
							<a href={item.href} target="_blank" rel="noreferrer" data-clicky>
								{item.title}
							</a>
						</h3>
						<p>{item.summary}</p>
						{item.tags.length ? (
							<div class="tag-row">
								{item.tags.map((tag: string) => <span>{tag}</span>)}
							</div>
						) : null}
					</article>
				))}
			</div>
		</section>

		<section id="tracks" class="notes-section" aria-labelledby="tracks-heading">
			<div class="section-heading">
				<h2 id="tracks-heading">Tracks</h2>
				<p>Longer writing from the blog, kept in the same reading space.</p>
			</div>

			<div class="notes-section-list">
				{tracks.map((item) => (
					<article class="notes-entry notes-track">
						<div class="notes-entry-meta">
							<span>Track</span>
							<time>{formatDate(item.date)}</time>
						</div>
						<h3>
							<a href={item.href} data-clicky>
								{item.title}
							</a>
						</h3>
						<p>{item.description}</p>
						{item.tags.length ? (
							<div class="tag-row">
								{item.tags.map((tag: string) => <span>{tag}</span>)}
							</div>
						) : null}
					</article>
				))}
			</div>
		</section>

		<section id="photos" class="notes-section" aria-labelledby="photos-heading">
			<div class="section-heading">
				<h2 id="photos-heading">Photos</h2>
				<p>Images pulled from notes and blog posts, linked back to where they live.</p>
			</div>

			<div class="photos-feed">
				{photoEntries.map((item) => (
					<a class="photo-story" href={item.href} data-clicky>
						<img src={item.image} alt={item.alt} loading="lazy" />
						<div class="photo-story-copy">
							<div class="notes-entry-meta">
								<span>{item.type === 'blog' ? 'Blog image' : 'Note image'}</span>
								<time>{formatDate(item.date)}</time>
							</div>
							<h3>{item.title}</h3>
							<p>{item.caption}</p>
						</div>
					</a>
				))}
			</div>
		</section>

		<section id="notes" class="notes-section" aria-labelledby="notes-heading">
			<div class="section-heading">
				<h2 id="notes-heading">Notes</h2>
				<p>Short pieces and small observations, shown in full.</p>
			</div>

			<div class="notes-section-list">
				{renderedNotes.map(({ note, Content }) => (
					<article id={slugToId(note.id)} class="notes-entry notes-note">
						<div class="notes-entry-meta">
							<span>Note</span>
							<time>{formatDate(note.data.date)}</time>
						</div>
						<h3>{note.data.title}</h3>
						{note.data.summary ? <p class="note-summary">{note.data.summary}</p> : null}

						{note.data.coverImage ? (
							<figure class="note-cover">
								<img
									src={note.data.coverImage}
									alt={note.data.coverImageAlt || note.data.title}
									loading="lazy"
								/>
							</figure>
						) : null}

						{note.data.images.length ? (
							<div class="note-images">
								{note.data.images.map((image: { src: string; alt: string; caption?: string }) => (
									<figure>
										<img src={image.src} alt={image.alt} loading="lazy" />
										{image.caption ? <figcaption>{image.caption}</figcaption> : null}
									</figure>
								))}
							</div>
						) : null}

						<div class="prose note-prose">
							<Content />
						</div>

						{note.data.authorNote ? (
							<section class="author-note note-author-note">
								<p class="author-note-label">Author's note</p>
								<p>{note.data.authorNote}</p>
							</section>
						) : null}

						{note.data.externalUrl ? (
							<p class="note-link">
								<a href={note.data.externalUrl} target="_blank" rel="noreferrer" data-clicky>
									Open link
								</a>
							</p>
						) : null}
					</article>
				))}
			</div>
		</section>
	</main>
</BaseLayout>
