---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';

const projects: CollectionEntry<'projects'>[] = (await getCollection('projects'))
	.filter((project: CollectionEntry<'projects'>) => !project.data.draft)
	.sort(
	(a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
		b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects - Prahlad Srinivasan" description="Projects by Prahlad Srinivasan.">
	<main class="content-page">
		<header class="page-top">
			<div>
				<h1>Projects</h1>
				<p>Work in progress, experiments, and larger things worth documenting properly.</p>
			</div>
		</header>

		<section class="project-list">
			{projects.map((project: CollectionEntry<'projects'>) => (
				<article class="list-card">
					{project.data.coverImage ? (
						<img
							class="list-card-cover"
							src={project.data.coverImage}
							alt={project.data.coverImageAlt || project.data.title}
							loading="lazy"
						/>
					) : null}
					<time>{formatDate(project.data.date)}</time>
					<h2>{project.data.title}</h2>
					<p>{project.data.description}</p>
					<div class="tag-row">
						<span>{project.data.status}</span>
						{project.data.tags.map((tag: string) => <span>{tag}</span>)}
					</div>
					{project.data.externalUrl ? (
						<p class="note-link">
							<a href={project.data.externalUrl} target="_blank" rel="noreferrer" data-clicky>
								Open project
							</a>
						</p>
					) : null}
					{project.data.authorNote ? (
						<section class="author-note project-author-note">
							<p class="author-note-label">Author's note</p>
							<p>{project.data.authorNote}</p>
						</section>
					) : null}
				</article>
			))}
		</section>
	</main>
</BaseLayout>
